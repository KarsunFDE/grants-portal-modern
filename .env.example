# grants-portal-modern — environment template
# Copy to .env and fill in real values. .env is git-ignored.

# --- Auth / JWT ---
JWT_ISSUER_URI=http://localhost:8090/auth
JWT_AUDIENCE=grants-portal-modern

# --- Datastores ---
POSTGRES_URL=jdbc:postgresql://localhost:5432/grants_portal_modern
POSTGRES_USER=app
POSTGRES_PASSWORD=app_dev_password

MONGO_URL=mongodb://app:app_dev_password@localhost:27017
MONGO_DB=grants_portal_modern

# --- AWS / Bedrock ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=anthropic.claude-3-7-sonnet-20250219-v1:0

# --- Inter-service ---
API_GATEWAY_URL=http://localhost:8080
SOLICITATION_SERVICE_URL=http://localhost:8081
EVALUATION_SERVICE_URL=http://localhost:8082
AI_ORCHESTRATOR_URL=http://localhost:8000
